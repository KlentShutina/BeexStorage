# BeexStorage backend — environment template
# Copy this file to `.env` and fill in your real values.
# Never commit the real `.env` (it's in .gitignore).

# Supabase Postgres (pooled connection — use this for runtime queries)
DATABASE_URL="postgresql://postgres.xxxxx:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase Postgres (direct connection — used by Prisma for migrations only)
DIRECT_URL="postgresql://postgres.xxxxx:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# Render assigns this automatically; locally defaults to 10000
# PORT=10000
