generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String        @id @default(cuid())
  username        String        @unique
  handle          String        @unique
  email           String        @unique
  password        String
  createdAt       DateTime      @default(now())
  joinRequests    JoinRequest[]
  memberships     Membership[]
  ordersRequested Order[]       @relation("OrderRequester")
  orderEvents     OrderEvent[]
  ownedStorages   Storage[]     @relation("OwnedStorages")
}

model Storage {
  id           String        @id @default(cuid())
  name         String
  handle       String        @unique
  deviceId     String?       @unique
  paired       Boolean       @default(false)
  isPublic     Boolean       @default(false)
  ownerId      String
  createdAt    DateTime      @default(now())
  joinRequests JoinRequest[]
  memberships  Membership[]
  orders       Order[]
  rows         Row[]
  owner        User          @relation("OwnedStorages", fields: [ownerId], references: [id])
  warehouses   Warehouse[]

  @@index([isPublic])
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  storageId String
  role      String
  isAdmin   Boolean  @default(false)
  joinedAt  DateTime @default(now())
  storage   Storage  @relation(fields: [storageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storageId])
  @@index([storageId])
}

model JoinRequest {
  id          String   @id @default(cuid())
  userId      String
  storageId   String
  requestedAt DateTime @default(now())
  status      String   @default("pending")
  storage     Storage  @relation(fields: [storageId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storageId])
  @@index([storageId, status])
}

model Row {
  id        String    @id @default(cuid())
  storageId String
  letter    String
  deletedAt DateTime?
  storage   Storage   @relation(fields: [storageId], references: [id], onDelete: Cascade)
  shelves   Shelf[]

  @@index([storageId])
}

model Shelf {
  id        String    @id @default(cuid())
  rowId     String
  coord     String
  label     String    @default("")
  quantity  Int       @default(0)
  isOpen    Boolean   @default(false)
  deletedAt DateTime?
  row       Row       @relation(fields: [rowId], references: [id], onDelete: Cascade)

  @@index([rowId])
}

model Warehouse {
  id            String  @id @default(cuid())
  storageId     String
  name          String
  contactUserId String?
  orders        Order[]
  storage       Storage @relation(fields: [storageId], references: [id], onDelete: Cascade)

  @@index([storageId])
}

model Order {
  id          String       @id @default(cuid())
  storageId   String
  requesterId String
  warehouseId String?
  item        String
  quantity    String
  status      String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  requester   User         @relation("OrderRequester", fields: [requesterId], references: [id])
  storage     Storage      @relation(fields: [storageId], references: [id], onDelete: Cascade)
  warehouse   Warehouse?   @relation(fields: [warehouseId], references: [id])
  events      OrderEvent[]

  @@index([storageId, status])
  @@index([requesterId])
}

model OrderEvent {
  id       String   @id @default(cuid())
  orderId  String
  status   String
  byUserId String
  at       DateTime @default(now())
  by       User     @relation(fields: [byUserId], references: [id])
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}
